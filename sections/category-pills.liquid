{{ 'component-category-pills.css' | asset_url | stylesheet_tag }}
<script src="{{ 'category-pills.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

    {%- if section.settings.sticky_navigation -%}
    .category-pills-section.is-sticky {
      position: sticky;
      top: 0;
      z-index: 99;
      box-shadow: 0 5px 15px rgba(0,0,0,0.05);
      border-bottom: 1px solid rgba(var(--color-foreground), 0.1);
      padding-top: 1rem !important;
      padding-bottom: 1rem !important;
      transition: all 0.3s ease;
      background-color: rgb(var(--color-background));
    }

    /* Ensure the header and sticky pills don't overlap if header is also sticky */
    .shopify-section-header-sticky + main .category-pills-section.is-sticky {
      top: var(--header-height, 60px);
    }
  {%- endif -%}

  {%- if section.settings.custom_colors -%}
    .section-{{ section.id }} {
      --color-foreground: {{ section.settings.color_text.red }}, {{ section.settings.color_text.green }}, {{ section.settings.color_text.blue }};
      --color-background: {{ section.settings.color_bg.red }}, {{ section.settings.color_bg.green }}, {{ section.settings.color_bg.blue }};
      background-color: rgb(var(--color-background));
    }
  {%- endif -%}

  .category-pill--back .category-pill__image-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(var(--color-foreground), 0.05);
  }

  .category-pill--back .category-pill__back-icon {
    display: flex;
    color: rgb(var(--color-foreground));
  }
{%- endstyle -%}

<div class="category-pills-section section-{{ section.id }} {% if section.settings.sticky_navigation %} is-sticky{% endif %} color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="section-heading-wrapper {% if section.settings.heading_alignment == 'center' %} center{% endif %}">
        <h2 class="category-pills__heading {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    {%- liquid
      assign links_to_display = section.settings.menu.links
      assign parent_link = null

      if section.settings.enable_dynamic_levels and section.settings.menu != blank
        comment
          Check for active sub-menus (Drill-down behavior)
        endcomment
        for link in section.settings.menu.links
          if link.active or link.child_active
            if link.links.size > 0
              assign links_to_display = link.links
              assign parent_link = section.settings.menu.links

              for child_link in link.links
                if child_link.active or child_link.child_active
                  if child_link.links.size > 0
                    assign links_to_display = child_link.links
                    assign parent_link = link
                    break
                  endif
                endif
              endfor

              comment
                If we are at the first level of child links, the back button should go back to the top-level collection or main menu.
              endcomment
              if parent_link == section.settings.menu.links
                assign parent_link = null
                assign show_root_back = true
              endif

              break
            endif
          endif
        endfor
      endif
    -%}

    <div class="category-pills {% if section.settings.center_pills %} category-pills--centered{% endif %}">
      <div class="category-pills__container">
        {%- if parent_link != null or show_root_back -%}
          {%- liquid
            assign back_url = parent_link.url | default: section.settings.menu_root_url | default: routes.all_products_collection_url
            assign back_label = section.settings.back_label | default: 'Back'
            if parent_link != null
              assign back_label = parent_link.title
            endif
          -%}
          <a href="{{ back_url }}" class="category-pill category-pill--back category-pill--circle">
            {%- if section.settings.show_images -%}
              <div class="category-pill__image-wrapper">
                <span class="category-pill__back-icon">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </div>
            {%- endif -%}
            <h2 class="category-pill__label">
              {%- unless section.settings.show_images -%}
                <span class="category-pill__back-icon--inline">
                  <svg
                    width="12"
                    height="12"
                    viewBox="0 0 24 24"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                    style="display:inline-block; vertical-align:middle; margin-right:4px;"
                  >
                    <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              {%- endunless -%}
              {{ back_label }}
            </h2>
          </a>
        {%- endif -%}

        {%- if links_to_display != blank -%}
          {%- for link in links_to_display -%}
            {%- liquid
              assign label = link.title
              assign url = link.url
              assign image = null

              if link.type == 'collection_link'
                assign collection = link.object
                assign image = collection.featured_image
                if label == blank
                  assign label = collection.title
                endif
              endif
            -%}
            {%- liquid
              assign is_active = false
              if request.path == url
                assign is_active = true
              elsif link.active or link.child_active
                assign is_active = true
              endif
            -%}
            {% render 'category-pill-item',
              image: image,
              label: label,
              link: url,
              show_images: section.settings.show_images,
              is_active: is_active
            %}
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Category Pills",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Browse by Category"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "Extra small"
        },
        {
          "value": "h1",
          "label": "Small"
        },
        {
          "value": "h0",
          "label": "Medium"
        }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ],
      "default": "left"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "info": "Select the menu to drive categories. Best for control over ordering and visibility."
    },
    {
      "type": "checkbox",
      "id": "enable_dynamic_levels",
      "label": "Enable dynamic drill-down",
      "info": "If the active category has a sub-menu, display those sub-categories instead of the main menu.",
      "default": true
    },
    {
      "type": "text",
      "id": "back_label",
      "label": "Back button label",
      "default": "Back"
    },
    {
      "type": "url",
      "id": "menu_root_url",
      "label": "Main categories link",
      "info": "Where the 'Back' button should lead from the first level of sub-categories."
    },
    {
      "type": "checkbox",
      "id": "sticky_navigation",
      "label": "Enable sticky navigation",
      "info": "Pills will stick to the top of the screen as you scroll (useful for mobile).",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_images",
      "label": "Show images",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "center_pills",
      "label": "Center pills on desktop",
      "default": false
    },
    {
      "type": "header",
      "content": "Color Scheme"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "custom_colors",
      "label": "Use custom colors",
      "default": false
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Custom text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Custom background color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Category Pills"
    }
  ]
}
{% endschema %}
