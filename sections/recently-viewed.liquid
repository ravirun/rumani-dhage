{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .recently-viewed__wrapper.hidden {
    display: none;
  }
{%- endstyle -%}

{{ 'quick-add.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>

<div class="recently-viewed__wrapper hidden section-{{ section.id }}-padding color-{{ section.settings.color_scheme }}" id="RecentlyViewed-{{ section.id }}" data-handle="{{ product.handle }}">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="title-wrapper-with-link title-wrapper--self-contained-mobile title-wrapper--no-top-margin">
        <h2 class="title {{ section.settings.heading_size }}">{{ section.settings.heading | escape }}</h2>
      </div>
    {%- endif -%}

    <ul class="grid product-grid grid--{{ section.settings.columns_mobile }}-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop" role="list" id="RecentlyViewedGrid-{{ section.id }}">
      {%- comment -%} JS will inject content here {%- endcomment -%}
    </ul>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const sectionId = '{{ section.id }}';
    const container = document.querySelector(`#RecentlyViewed-${sectionId}`);
    const grid = document.querySelector(`#RecentlyViewedGrid-${sectionId}`);
    const currentHandle = container.dataset.handle;
    
    // 1. Get history from localStorage
    let history = JSON.parse(localStorage.getItem('recentlyViewed') || '[]');
    
    // 2. Add current product to history if on product page
    if (window.location.pathname.includes('/products/') && currentHandle) {
      history = history.filter(h => h !== currentHandle);
      history.unshift(currentHandle);
      localStorage.setItem('recentlyViewed', JSON.stringify(history.slice(0, 10)));
    }

    // 3. Render list (excluding current product)
    const itemsToShow = history.filter(h => h !== currentHandle).slice(0, {{ section.settings.products_to_show }});
    
    if (itemsToShow.length > 0) {
      container.classList.remove('hidden');
      
      const requests = itemsToShow.map(handle => 
        fetch(`${window.routes.root_url}products/${handle}?view=recently-viewed-card`)
          .then(res => res.text())
      );

      Promise.all(requests).then(htmls => {
        grid.innerHTML = htmls.join('');
      });
    }
  });
</script>

{% schema %}
{
  "name": "Recently Viewed Products",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Recently Viewed",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading Size"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "Number of columns on desktop"
    },
    {
        "type": "select",
        "id": "columns_mobile",
        "options": [
          { "value": "1", "label": "1 column" },
          { "value": "2", "label": "2 columns" }
        ],
        "default": "2",
        "label": "Number of columns on mobile"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Recently Viewed Products"
    }
  ]
}
{% endschema %}
